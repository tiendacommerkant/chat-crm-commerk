# ============================================
# CHATBOT CRM COMMERK - Variables de Entorno
# ============================================

# ────────────────────────────────────────────
# WHATSAPP BUSINESS API (Meta Cloud API)
# ────────────────────────────────────────────
# Obtén estos valores en: https://developers.facebook.com/
# 1. Crea una app de tipo "Business"
# 2. Agrega el producto "WhatsApp"
# 3. Copia el Phone Number ID y Access Token

WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_VERIFY_TOKEN=tu_token_secreto_aleatorio_12345

# ────────────────────────────────────────────
# SUPABASE (Base de Datos)
# ────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard
# Proyecto > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ────────────────────────────────────────────
# SHOPIFY (E-commerce)
# ────────────────────────────────────────────
# Admin > Apps > Develop apps > Create app
# Configura estos permisos: read_products, read_inventory

SHOPIFY_STORE=tiendacommerkant
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────
# WOMPI (Pasarela de Pagos Colombia)
# ────────────────────────────────────────────
# Obtén las keys en: https://comercios.wompi.co/
# Dashboard > Configuración > API Keys

WOMPI_PUBLIC_KEY=pub_prod_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_prod_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_EVENT_SECRET=prod_event_xxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────
# OPENAI (Opcional - Para IA del bot)
# ────────────────────────────────────────────
# Si no usas IA, el bot funciona con reglas predefinidas
# Si quieres IA inteligente, crea key en: https://platform.openai.com/

OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
USE_AI_BOT=false  # true para usar GPT-4, false para reglas básicas

# ────────────────────────────────────────────
# URL BASE (Para webhooks)
# ────────────────────────────────────────────
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ────────────────────────────────────────────
# CONFIGURACIÓN DEL NEGOCIO
# ────────────────────────────────────────────

BUSINESS_NAME="Tienda Commerk Antioquia"
BUSINESS_PHONE=573183349171
BUSINESS_EMAIL=contacto@tiendacommerkant.com.co

# Cobertura de envíos (separado por comas)
SHIPPING_COVERAGE="Caldas,La Estrella,Sabaneta,Envigado,Medellín,Bello,Copacabana"
SHIPPING_COST=8000
FREE_SHIPPING_THRESHOLD=149000

# ────────────────────────────────────────────
# NOTIFICACIONES
# ────────────────────────────────────────────
# Email para recibir alertas de ventas
NOTIFICATION_EMAIL=ventas@tiendacommerkant.com.co

# Slack webhook (opcional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX
